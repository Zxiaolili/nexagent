# LLM Provider Configuration
# Choose one provider:

# Anthropic (default)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# NEXAGENT_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# OpenAI-compatible (e.g. DeepSeek, local models)
# NEXAGENT_PROVIDER=openai-compatible
# NEXAGENT_API_KEY=your-key
# NEXAGENT_BASE_URL=https://api.deepseek.com/v1
# NEXAGENT_MODEL=deepseek-chat

# Qwen (通义千问, DashScope or custom base URL)
# NEXAGENT_PROVIDER=qwen
# NEXAGENT_API_KEY=your-key
# NEXAGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# NEXAGENT_MODEL=qwen-plus

# Dev: browser calls core directly (required for proper SSE streaming)
NEXT_PUBLIC_CORE_URL=http://localhost:3457

# Optional: custom directories
# NEXAGENT_PROJECTS_DIR=~/nexagent-projects
# NEXAGENT_PORT=3457
